APP_NAME="Powerhouse"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://hub.whitedash.co.uk
PORTAL_URL=https://account.whitedash.co.uk
REFERRER_URL=https://referrers.whitedash.co.uk

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=powerhouse
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Set to true in production (HTTPS only)
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_EXPIRE_ON_CLOSE=false
DEBUGBAR_ENABLED=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────────────
# Powerhouse-specific
# ─────────────────────────────────────────────────────────────────────────

# Bootstrap super-admin (seeder reads these)
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Billing entities (seeder reads these)
MAAVELUS_LEGAL_NAME="Maavelus Ltd"
MAAVELUS_COMPANY_NUMBER=
MAAVELUS_VAT_NUMBER=
KONSTRAKT_LEGAL_NAME="Konstrakt Ltd"
KONSTRAKT_COMPANY_NUMBER=
KONSTRAKT_VAT_NUMBER=

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Postmark
POSTMARK_TOKEN=

# Stripe
STRIPE_KEY=
STRIPE_SECRET=

# QuickBooks Online
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=

# OAuth: Maavelus Control Panel
MAAVELUS_OAUTH_CLIENT_ID=
MAAVELUS_POWERHOUSE_SUMMARY_URL=

# OAuth: MyOrderPad
MYORDERPAD_OAUTH_CLIENT_ID=
MYORDERPAD_POWERHOUSE_SUMMARY_URL=

# OAuth: Whitedash main
WHITEDASH_POWERHOUSE_SUMMARY_URL=
